{
  "expo": {
    "name": "SKC Caterers",
    "slug": "skc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "extra": {
      "eas": {
        "projectId": "9ce393ef-d771-4c9c-8fd0-bc2add5dc81b"
      }
    },
    "splash": {
      "image": "./src/assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.skccaterers.mobile",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow SKC Caterers to use your location to track deliveries in the background.",
          "locationAlwaysPermission": "Allow SKC Caterers to use your location to track deliveries in the background.",
          "locationWhenInUsePermission": "Allow SKC Caterers to use your location to track your deliveries."
        }
      ]
    ]
  }
}
